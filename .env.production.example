# Production trading config. Paper mode is the safe default.
TRADING_MODE=paper
BROKER=paper
ENABLE_LIVE_TRADING=false
TRADING_PAIRS=XAUUSD,GBPUSD,USDJPY,AUDUSD
TRADE_INTERVAL_SECONDS=3600
MAX_TRADING_CYCLES=0
ORDER_UNITS=1
MAX_POSITION_UNITS=3
MAX_ORDERS_PER_CYCLE=4
MAX_DAILY_LOSS=50
PRODUCTION_MODEL_PATH=models/improved_hybrid_trading_agent.zip
TRADE_LEDGER_PATH=logs/trade_ledger.jsonl
PAPER_BROKER_STATE=logs/paper_broker_state.json
KILL_SWITCH_FILE=STOP_TRADING

# Existing market data keys
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
FRED_API_KEY=your-fred-api-key
NEWS_API_KEY=your-news-api-key

# OANDA live/practice execution. Only used when BROKER=oanda.
OANDA_ENV=practice
OANDA_API_KEY=your-oanda-api-key
OANDA_ACCOUNT_ID=your-oanda-account-id
